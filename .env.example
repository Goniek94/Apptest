# ─────────────────────────────────────────────────────────────────────────────
# ModaMarket — przykładowa konfiguracja (Etap 1).
# Skopiuj do `.env` w korzeniu monorepo:  cp .env.example .env
# Wartości poniżej to placeholdery — podmień na własne.
# Kontrakt egzekwowany jest w apps/api/src/config/env.validation.ts (fail-fast).
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="4000"
FRONTEND_URL="http://localhost:3000"

# ── Baza danych (Prisma / PostgreSQL) ────────────────────────────────────────
# DATABASE_URL — połączenie aplikacyjne (pooled, np. PgBouncer/Supabase :6543).
# DIRECT_URL   — połączenie bezpośrednie (:5432) używane przez migracje Prisma.
#                Wymagane przez `prisma migrate` i bezpieczne dla `prisma validate`.
DATABASE_URL="postgresql://user:password@localhost:5432/modamarket?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/modamarket?schema=public"

# ── JWT (min. 16 znaków każdy; access i refresh MUSZĄ się różnić) ─────────────
JWT_ACCESS_SECRET="zmien-mnie-na-losowy-sekret-min-16-znakow"
JWT_REFRESH_SECRET="inny-losowy-sekret-min-16-znakow-rozny-od-access"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Supabase Storage (backend, service_role) ─────────────────────────────────
SUPABASE_URL="https://twoj-projekt.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service-role-key-z-supabase"

# ── Frontend (apps/web — Next.js, zmienne publiczne) ─────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_SUPABASE_URL="https://twoj-projekt.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="anon-public-key-z-supabase"

# ── Etap 2 (jeszcze nieużywane — operator płatności) ─────────────────────────
# PAYMENTS_PROVIDER="TPAY"
# PAYMENTS_API_KEY=""
# PAYMENTS_API_SECRET=""
